# Banco de dados
POSTGRES_DB=encontro_carona
POSTGRES_USER=encontro
POSTGRES_PASSWORD=troque-esta-senha-do-postgres

# Backend / JWT
# Gere com: openssl rand -base64 48
APP_JWT_SECRET=troque-por-uma-chave-com-mais-de-32-caracteres
APP_JWT_EXPIRATION_MINUTES=480

# Admin inicial
# Usado apenas se ainda não existir nenhum usuário na tabela de usuários.
APP_ADMIN_USERNAME=admin
APP_ADMIN_INITIAL_PASSWORD=troque-esta-senha-admin
APP_ADMIN_NAME=Administrador

# CORS
# Para acesso por IP, use http://SEU_IP_DA_VPS
# Para domínio, use https://tio-carona.seudominio.com.br
APP_CORS_ALLOWED_ORIGINS=http://SEU_IP_DA_VPS

# JVM
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=70 -XX:+UseContainerSupport
