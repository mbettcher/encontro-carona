<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="lista_presenca_tios_carona_duplas"
              language="java"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">

    <style name="Titulo" fontName="SansSerif" fontSize="16" isBold="false" forecolor="#FFFFFF"/>
    <style name="Subtitulo" fontName="SansSerif" fontSize="8" forecolor="#FFFFFF"/>
    <style name="Info" fontName="SansSerif" fontSize="7" forecolor="#111827"/>
    <style name="Cabecalho" fontName="SansSerif" fontSize="8" forecolor="#111827"/>
    <style name="Texto" fontName="SansSerif" fontSize="9" forecolor="#111827"/>
    <style name="TextoPequeno" fontName="SansSerif" fontSize="6" isItalic="true" forecolor="#111827"/>
    <style name="Numero" fontName="SansSerif" fontSize="8" forecolor="#111827"/>

    <parameter name="EVENTO_NOME" class="java.lang.String"/>
    <parameter name="PAROQUIA_NOME" class="java.lang.String"/>
    <parameter name="EVENTO_LOCAL" class="java.lang.String"/>
    <parameter name="EVENTO_PERIODO" class="java.lang.String"/>
    <parameter name="EMITIDO_EM" class="java.lang.String"/>
    <parameter name="FILTROS" class="java.lang.String"/>
    <parameter name="TOTAL_REGISTROS" class="java.lang.Integer"/>

    <field name="numero" class="java.lang.Integer"/>
    <field name="apelidoDupla" class="java.lang.String"/>
    <field name="paroquiaComunidadeNome" class="java.lang.String"/>
    <field name="paroquiaComunidadeEndereco" class="java.lang.String"/>
    <field name="tio1Nome" class="java.lang.String"/>
    <field name="tio2Nome" class="java.lang.String"/>

    <title>
        <band height="110">
            <rectangle>
                <reportElement mode="Opaque" x="0" y="0" width="802" height="52" backcolor="#1F2937"/>
                <graphicElement>
                    <pen lineWidth="0.5" lineColor="#111827"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement style="Titulo" x="18" y="9" width="500" height="22" forecolor="#FFFFFF"/>
                <text><![CDATA[Lista de Presença — Tios Carona por Dupla]]></text>
            </staticText>

            <textField>
                <reportElement style="Subtitulo" x="18" y="33" width="430" height="12" forecolor="#FFFFFF"/>
                <textFieldExpression><![CDATA["Evento: " + $P{EVENTO_NOME}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="Subtitulo" x="600" y="11" width="188" height="12" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA["Emitido em " + $P{EMITIDO_EM}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="Subtitulo" x="600" y="33" width="188" height="12" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA["Total: " + $P{TOTAL_REGISTROS} + " dupla(s)"]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement mode="Opaque" x="0" y="64" width="802" height="42" backcolor="#F9FAFB"/>
                <graphicElement>
                    <pen lineWidth="0.35" lineColor="#CBD5E1"/>
                </graphicElement>
            </rectangle>

            <textField>
                <reportElement style="Info" x="12" y="72" width="380" height="10"/>
                <textFieldExpression><![CDATA["Paróquia/Comunidade: " + $P{PAROQUIA_NOME}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="Info" x="12" y="90" width="380" height="10"/>
                <textFieldExpression><![CDATA["Período: " + $P{EVENTO_PERIODO}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="Info" x="410" y="72" width="380" height="10"/>
                <textFieldExpression><![CDATA["Local: " + $P{EVENTO_LOCAL}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="Info" x="410" y="90" width="380" height="10"/>
                <textFieldExpression><![CDATA["Filtros: " + $P{FILTROS}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="24">
            <rectangle>
                <reportElement mode="Opaque" x="0" y="0" width="802" height="22" backcolor="#E5E7EB"/>
                <graphicElement>
                    <pen lineWidth="0.35" lineColor="#CBD5E1"/>
                </graphicElement>
            </rectangle>
            <staticText><reportElement style="Cabecalho" x="6" y="7" width="35" height="8"/><text><![CDATA[Ord.]]></text></staticText>
            <staticText><reportElement style="Cabecalho" x="55" y="7" width="160" height="8"/><text><![CDATA[Apelido da Dupla]]></text></staticText>
            <staticText><reportElement style="Cabecalho" x="230" y="7" width="235" height="8"/><text><![CDATA[Paróquia/Comunidade]]></text></staticText>
            <staticText><reportElement style="Cabecalho" x="480" y="7" width="165" height="8"/><text><![CDATA[Integrantes]]></text></staticText>
            <staticText><reportElement style="Cabecalho" x="660" y="7" width="130" height="8"/><text><![CDATA[Assinaturas]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="58" splitType="Stretch">
            <textField>
                <reportElement style="Numero" x="6" y="22" width="30" height="10"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{numero}]]></textFieldExpression>
            </textField>

            <textField textAdjust="StretchHeight">
                <reportElement style="Texto" x="55" y="19" width="160" height="14"/>
                <textFieldExpression><![CDATA[$F{apelidoDupla}]]></textFieldExpression>
            </textField>

            <textField textAdjust="StretchHeight">
                <reportElement style="Texto" x="230" y="12" width="235" height="12"/>
                <textFieldExpression><![CDATA[$F{paroquiaComunidadeNome}]]></textFieldExpression>
            </textField>

            <textField textAdjust="StretchHeight">
                <reportElement style="TextoPequeno" x="230" y="31" width="235" height="14"/>
                <textFieldExpression><![CDATA[$F{paroquiaComunidadeEndereco}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="Texto" x="480" y="9" width="165" height="12"/>
                <textFieldExpression><![CDATA[$F{tio1Nome}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="480" y="28" width="300" height="1" forecolor="#E5E7EB"/>
            </line>

            <textField>
                <reportElement style="Texto" x="480" y="36" width="165" height="12"/>
                <textFieldExpression><![CDATA[$F{tio2Nome}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="660" y="23" width="120" height="1" forecolor="#6B7280"/>
            </line>

            <line>
                <reportElement x="660" y="50" width="120" height="1" forecolor="#6B7280"/>
            </line>

            <line>
                <reportElement x="0" y="56" width="802" height="1" forecolor="#E5E7EB"/>
            </line>
        </band>
    </detail>

    <summary>
        <band height="24">
            <rectangle>
                <reportElement mode="Opaque" x="0" y="3" width="802" height="20" backcolor="#F9FAFB"/>
                <graphicElement>
                    <pen lineWidth="0.35" lineColor="#CBD5E1"/>
                </graphicElement>
            </rectangle>
            <textField>
                <reportElement style="Info" x="600" y="9" width="188" height="10"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA["Total de duplas listadas: " + $P{TOTAL_REGISTROS}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
