<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="cadernos_equipes"
              language="java"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">

    <style name="TituloRelatorio" fontName="SansSerif" fontSize="16" isBold="true" forecolor="#FFFFFF"/>
    <style name="SubtituloRelatorio" fontName="SansSerif" fontSize="9" forecolor="#E5E7EB"/>
    <style name="TextoBase" fontName="SansSerif" fontSize="8" forecolor="#111827"/>
    <style name="TextoPequeno" fontName="SansSerif" fontSize="7" forecolor="#374151"/>
    <style name="CabecalhoColuna" fontName="SansSerif" fontSize="8" isBold="true" forecolor="#111827"/>
    <style name="GrupoEquipe" fontName="SansSerif" fontSize="10" isBold="true" forecolor="#1F2937"/>

    <parameter name="EVENTO_NOME" class="java.lang.String"/>
    <parameter name="PAROQUIA_NOME" class="java.lang.String"/>
    <parameter name="EVENTO_LOCAL" class="java.lang.String"/>
    <parameter name="EVENTO_PERIODO" class="java.lang.String"/>
    <parameter name="EMITIDO_EM" class="java.lang.String"/>
    <parameter name="FILTROS" class="java.lang.String"/>
    <parameter name="TOTAL_REGISTROS" class="java.lang.Integer"/>

    <field name="equipeApelido" class="java.lang.String"/>
    <field name="sobrinhoNome" class="java.lang.String"/>
    <field name="dupla" class="java.lang.String"/>
    <field name="tiosCarona" class="java.lang.String"/>
    <field name="status" class="java.lang.String"/>
    <field name="recebidoDaDuplaEm" class="java.lang.String"/>
    <field name="conferidoEm" class="java.lang.String"/>
    <field name="anexadoAoKitEm" class="java.lang.String"/>

    <group name="EquipeGroup">
        <groupExpression><![CDATA[$F{equipeApelido}]]></groupExpression>
        <groupHeader>
            <band height="26">
                <rectangle>
                    <reportElement mode="Opaque" x="0" y="4" width="802" height="18" backcolor="#F3F4F6"/>
                    <graphicElement>
                        <pen lineWidth="0.5" lineColor="#D1D5DB"/>
                    </graphicElement>
                </rectangle>
                <textField>
                    <reportElement style="GrupoEquipe" x="8" y="6" width="500" height="14"/>
                    <textElement verticalAlignment="Middle"/>
                    <textFieldExpression><![CDATA["Equipe: " + $F{equipeApelido}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
    </group>

    <title>
        <band height="118">
            <rectangle>
                <reportElement mode="Opaque" x="0" y="0" width="802" height="52" backcolor="#1F2937"/>
            </rectangle>

            <staticText>
                <reportElement style="TituloRelatorio" x="18" y="8" width="520" height="22"/>
                <textElement verticalAlignment="Middle"/>
                <text><![CDATA[Cadernos de Mensagens por Equipe do Kit]]></text>
            </staticText>

            <textField>
                <reportElement style="SubtituloRelatorio" x="18" y="31" width="520" height="13"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA["Evento: " + $P{EVENTO_NOME}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="SubtituloRelatorio" x="595" y="10" width="190" height="13"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA["Emitido em " + $P{EMITIDO_EM}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="SubtituloRelatorio" x="595" y="29" width="190" height="13"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA["Total: " + $P{TOTAL_REGISTROS} + " caderno(s)"]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement mode="Opaque" x="0" y="64" width="802" height="42" backcolor="#F9FAFB"/>
                <graphicElement>
                    <pen lineWidth="0.5" lineColor="#E5E7EB"/>
                </graphicElement>
            </rectangle>

            <textField>
                <reportElement style="TextoBase" x="12" y="70" width="385" height="12"/>
                <textFieldExpression><![CDATA["Paróquia: " + $P{PAROQUIA_NOME}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="TextoBase" x="410" y="70" width="380" height="12"/>
                <textFieldExpression><![CDATA["Local: " + $P{EVENTO_LOCAL}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="TextoBase" x="12" y="88" width="385" height="12"/>
                <textFieldExpression><![CDATA["Período: " + $P{EVENTO_PERIODO}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="TextoBase" x="410" y="88" width="380" height="12"/>
                <textFieldExpression><![CDATA["Filtros: " + $P{FILTROS}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="24">
            <rectangle>
                <reportElement mode="Opaque" x="0" y="0" width="802" height="22" backcolor="#E5E7EB"/>
                <graphicElement>
                    <pen lineWidth="0.5" lineColor="#D1D5DB"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement style="CabecalhoColuna" x="4" y="5" width="108" height="12"/>
                <text><![CDATA[Encontrista]]></text>
            </staticText>
            <staticText>
                <reportElement style="CabecalhoColuna" x="116" y="5" width="88" height="12"/>
                <text><![CDATA[Dupla]]></text>
            </staticText>
            <staticText>
                <reportElement style="CabecalhoColuna" x="208" y="5" width="166" height="12"/>
                <text><![CDATA[Tios carona]]></text>
            </staticText>
            <staticText>
                <reportElement style="CabecalhoColuna" x="378" y="5" width="92" height="12"/>
                <text><![CDATA[Status]]></text>
            </staticText>
            <staticText>
                <reportElement style="CabecalhoColuna" x="474" y="5" width="64" height="12"/>
                <text><![CDATA[Recebido]]></text>
            </staticText>
            <staticText>
                <reportElement style="CabecalhoColuna" x="542" y="5" width="64" height="12"/>
                <text><![CDATA[Conferido]]></text>
            </staticText>
            <staticText>
                <reportElement style="CabecalhoColuna" x="610" y="5" width="64" height="12"/>
                <text><![CDATA[No kit]]></text>
            </staticText>
            <staticText>
                <reportElement style="CabecalhoColuna" x="685" y="5" width="110" height="12"/>
                <text><![CDATA[Assinatura]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="32">
            <textField isStretchWithOverflow="true">
                <reportElement style="TextoPequeno" x="4" y="3" width="108" height="24"/>
                <textElement verticalAlignment="Top"/>
                <textFieldExpression><![CDATA[$F{sobrinhoNome}]]></textFieldExpression>
            </textField>

            <textField isStretchWithOverflow="true">
                <reportElement style="TextoPequeno" x="116" y="3" width="88" height="24"/>
                <textElement verticalAlignment="Top"/>
                <textFieldExpression><![CDATA[$F{dupla}]]></textFieldExpression>
            </textField>

            <textField isStretchWithOverflow="true">
                <reportElement style="TextoPequeno" x="208" y="3" width="166" height="24"/>
                <textElement verticalAlignment="Top"/>
                <textFieldExpression><![CDATA[$F{tiosCarona}]]></textFieldExpression>
            </textField>

            <textField isStretchWithOverflow="true">
                <reportElement style="TextoPequeno" x="378" y="3" width="92" height="24"/>
                <textElement verticalAlignment="Top"/>
                <textFieldExpression><![CDATA[$F{status}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="TextoPequeno" x="474" y="3" width="64" height="24"/>
                <textElement verticalAlignment="Top"/>
                <textFieldExpression><![CDATA[$F{recebidoDaDuplaEm}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="TextoPequeno" x="542" y="3" width="64" height="24"/>
                <textElement verticalAlignment="Top"/>
                <textFieldExpression><![CDATA[$F{conferidoEm}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="TextoPequeno" x="610" y="3" width="64" height="24"/>
                <textElement verticalAlignment="Top"/>
                <textFieldExpression><![CDATA[$F{anexadoAoKitEm}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="685" y="20" width="110" height="1" forecolor="#6B7280"/>
            </line>

            <line>
                <reportElement x="0" y="31" width="802" height="1" forecolor="#E5E7EB"/>
            </line>
        </band>
    </detail>

    <pageFooter>
        <band height="22">
            <line>
                <reportElement x="0" y="1" width="802" height="1" forecolor="#E5E7EB"/>
            </line>

            <textField>
                <reportElement style="TextoPequeno" x="0" y="6" width="420" height="12"/>
                <textFieldExpression><![CDATA["Gerado pelo sistema Tio Carona"]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="TextoPequeno" x="650" y="6" width="152" height="12"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <summary>
        <band height="34">
            <rectangle>
                <reportElement mode="Opaque" x="0" y="6" width="802" height="20" backcolor="#F9FAFB"/>
                <graphicElement>
                    <pen lineWidth="0.5" lineColor="#E5E7EB"/>
                </graphicElement>
            </rectangle>

            <textField>
                <reportElement style="TextoBase" x="12" y="10" width="778" height="12"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA["Total de cadernos listados: " + $P{TOTAL_REGISTROS}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
