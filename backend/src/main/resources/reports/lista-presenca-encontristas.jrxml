<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="lista_presenca_encontristas"
              language="java"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">

    <style name="Titulo" fontName="SansSerif" fontSize="16" isBold="false" forecolor="#FFFFFF"/>
    <style name="Subtitulo" fontName="SansSerif" fontSize="8" forecolor="#FFFFFF"/>
    <style name="Info" fontName="SansSerif" fontSize="7" forecolor="#111827"/>
    <style name="Cabecalho" fontName="SansSerif" fontSize="7" forecolor="#111827"/>
    <style name="Grupo" fontName="SansSerif" fontSize="10" forecolor="#111827"/>
    <style name="Texto" fontName="SansSerif" fontSize="6" forecolor="#111827"/>
    <style name="Numero" fontName="SansSerif" fontSize="6" forecolor="#111827"/>

    <parameter name="EVENTO_NOME" class="java.lang.String"/>
    <parameter name="PAROQUIA_NOME" class="java.lang.String"/>
    <parameter name="EVENTO_LOCAL" class="java.lang.String"/>
    <parameter name="EVENTO_PERIODO" class="java.lang.String"/>
    <parameter name="EMITIDO_EM" class="java.lang.String"/>
    <parameter name="FILTROS" class="java.lang.String"/>
    <parameter name="TOTAL_REGISTROS" class="java.lang.Integer"/>

    <field name="numero" class="java.lang.Integer"/>
    <field name="nome" class="java.lang.String"/>
    <field name="dupla" class="java.lang.String"/>
    <field name="tiosCarona" class="java.lang.String"/>
    <field name="responsavel" class="java.lang.String"/>
    <field name="observacao" class="java.lang.String"/>

    <group name="GrupoDupla">
        <groupExpression><![CDATA[$F{dupla}]]></groupExpression>
        <groupHeader>
            <band height="26">
                <rectangle>
                    <reportElement mode="Opaque" x="0" y="6" width="802" height="18" backcolor="#F3F4F6"/>
                    <graphicElement>
                        <pen lineWidth="0.35" lineColor="#CBD5E1"/>
                    </graphicElement>
                </rectangle>
                <textField>
                    <reportElement style="Grupo" x="8" y="9" width="780" height="12"/>
                    <textFieldExpression><![CDATA["Dupla: " + $F{dupla}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
    </group>

    <title>
        <band height="110">
            <rectangle>
                <reportElement mode="Opaque" x="0" y="0" width="802" height="52" backcolor="#1F2937"/>
                <graphicElement>
                    <pen lineWidth="0.5" lineColor="#111827"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement style="Titulo" x="18" y="9" width="500" height="22" forecolor="#FFFFFF"/>
                <text><![CDATA[Lista de Presença — Encontristas]]></text>
            </staticText>

            <textField>
                <reportElement style="Subtitulo" x="18" y="33" width="430" height="12" forecolor="#FFFFFF"/>
                <textFieldExpression><![CDATA["Evento: " + $P{EVENTO_NOME}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="Subtitulo" x="600" y="11" width="188" height="12" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA["Emitido em " + $P{EMITIDO_EM}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="Subtitulo" x="600" y="33" width="188" height="12" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA["Total: " + $P{TOTAL_REGISTROS} + " registro(s)"]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement mode="Opaque" x="0" y="64" width="802" height="42" backcolor="#F9FAFB"/>
                <graphicElement>
                    <pen lineWidth="0.35" lineColor="#CBD5E1"/>
                </graphicElement>
            </rectangle>

            <textField>
                <reportElement style="Info" x="12" y="72" width="380" height="10"/>
                <textFieldExpression><![CDATA["Paróquia/Comunidade: " + $P{PAROQUIA_NOME}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="Info" x="12" y="90" width="380" height="10"/>
                <textFieldExpression><![CDATA["Período: " + $P{EVENTO_PERIODO}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="Info" x="410" y="72" width="380" height="10"/>
                <textFieldExpression><![CDATA["Local: " + $P{EVENTO_LOCAL}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement style="Info" x="410" y="90" width="380" height="10"/>
                <textFieldExpression><![CDATA["Filtros: " + $P{FILTROS}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="24">
            <rectangle>
                <reportElement mode="Opaque" x="0" y="0" width="802" height="22" backcolor="#E5E7EB"/>
                <graphicElement>
                    <pen lineWidth="0.35" lineColor="#CBD5E1"/>
                </graphicElement>
            </rectangle>
            <staticText><reportElement style="Cabecalho" x="6" y="7" width="30" height="8"/><text><![CDATA[Nº]]></text></staticText>
            <staticText><reportElement style="Cabecalho" x="38" y="7" width="180" height="8"/><text><![CDATA[Encontrista]]></text></staticText>
            <staticText><reportElement style="Cabecalho" x="230" y="7" width="190" height="8"/><text><![CDATA[Tios carona]]></text></staticText>
            <staticText><reportElement style="Cabecalho" x="425" y="7" width="140" height="8"/><text><![CDATA[Responsável]]></text></staticText>
            <staticText><reportElement style="Cabecalho" x="580" y="7" width="145" height="8"/><text><![CDATA[Assinatura]]></text></staticText>
            <staticText><reportElement style="Cabecalho" x="735" y="7" width="60" height="8"/><text><![CDATA[Obs.]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="40">
            <textField>
                <reportElement style="Numero" x="6" y="9" width="25" height="10"/>
                <textFieldExpression><![CDATA[$F{numero}]]></textFieldExpression>
            </textField>

            <textField textAdjust="StretchHeight">
                <reportElement style="Texto" x="38" y="9" width="180" height="12"/>
                <textFieldExpression><![CDATA[$F{nome}]]></textFieldExpression>
            </textField>

            <textField textAdjust="StretchHeight">
                <reportElement style="Texto" x="230" y="9" width="185" height="12"/>
                <textFieldExpression><![CDATA[$F{tiosCarona}]]></textFieldExpression>
            </textField>

            <textField textAdjust="StretchHeight">
                <reportElement style="Texto" x="425" y="9" width="140" height="12"/>
                <textFieldExpression><![CDATA[$F{responsavel}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="580" y="28" width="145" height="1" forecolor="#6B7280"/>
            </line>

            <textField textAdjust="StretchHeight">
                <reportElement style="Texto" x="735" y="9" width="60" height="12"/>
                <textFieldExpression><![CDATA[$F{observacao}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="38" width="802" height="1" forecolor="#E5E7EB"/>
            </line>
        </band>
    </detail>

    <summary>
        <band height="24">
            <rectangle>
                <reportElement mode="Opaque" x="0" y="3" width="802" height="20" backcolor="#F9FAFB"/>
                <graphicElement>
                    <pen lineWidth="0.35" lineColor="#CBD5E1"/>
                </graphicElement>
            </rectangle>
            <textField>
                <reportElement style="Info" x="600" y="9" width="188" height="10"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA["Total de registros listados: " + $P{TOTAL_REGISTROS}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
